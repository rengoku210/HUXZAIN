# ============================================================
# HUXZAIN — Environment Configuration
# Copy to .env.local and fill values. Anything prefixed VITE_ is
# embedded in the browser bundle. Server-only secrets MUST NOT
# use the VITE_ prefix.
# ============================================================

# --- Supabase (browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Supabase (server) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- WordPress CMS bridge (optional) ---
VITE_WORDPRESS_API_BASE=

# --- Razorpay (payments) ---
VITE_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@huxzain.shop

# --- OTP / email verification ---
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5

# --- Cloudinary (optional unsigned uploads) ---
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=huxzain_unsigned
