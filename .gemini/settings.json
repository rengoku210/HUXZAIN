{
  "mcpServers": {
    "vercel": {
      "url": "https://mcp.vercel.com",
      "type": "sse"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp",
      "type": "sse"
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@github/github-mcp-server"
      ]
    }
  }
}